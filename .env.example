# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
# Never commit the real .env — it is ignored via .gitignore.
# ---------------------------------------------------------------------------

# Gemini API — used for OQLF French translation.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Hugging Face token — REQUIRED for speaker diarization (pyannote models).
# Create one at https://huggingface.co/settings/tokens and accept the
# pyannote/speaker-diarization-3.1 model license.
HF_TOKEN=your_huggingface_token_here

# Google Cloud credentials — path to your Text-to-Speech service-account JSON.
GOOGLE_APPLICATION_CREDENTIALS=./creds/google_tts_service_account.json

# Default settings (optional).
DEFAULT_TTS_LANG=fr-CA
WHISPER_MODEL=small
