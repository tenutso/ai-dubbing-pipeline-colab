# ---------------------------------------------------------------------------
# Copy this file to ".env" and fill in your own values.
#   cp .env.example .env
# Never commit the real .env — it is ignored via .gitignore.
# ---------------------------------------------------------------------------

# Gemini API — used for OQLF French translation.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# Hugging Face token — REQUIRED for speaker diarization (pyannote models).
# Create one at https://huggingface.co/settings/tokens and accept the
# pyannote/speaker-diarization-3.1 model license.
HF_TOKEN=your_huggingface_token_here

# XTTS-V2 synthesis defaults (optional — override via CLI flags).
# TTS_LANG: ISO 639-1 code accepted by XTTS-V2 (fr, en, es, de, it, pt, …)
TTS_LANG=fr
# TTS_TEMPERATURE: expressiveness dial — 0.1 (consistent) to 1.0 (expressive)
TTS_TEMPERATURE=0.65

# WhisperX defaults (optional).
WHISPER_MODEL=small
